config frpc 'common'
	option enabled '1'
	option server_addr 'frps.example.com'
	option server_port '7000'
	# option auth_token 'your_token_here'
	option log_level 'info'
	option log_max_days '3'

config proxy 'rich_http'
	option enabled '1'
	option name 'rich-http'
	option type 'tcp'
	option local_ip '127.0.0.1'
	option local_port '80'
	option remote_port '9880'

config proxy 'rich_ssh'
	option enabled '1'
	option name 'rich-ssh'
	option type 'tcp'
	option local_ip '127.0.0.1'
	option local_port '22'
	option remote_port '9822'
